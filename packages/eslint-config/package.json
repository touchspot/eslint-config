{
	"name": "@touchspot/eslint-config",
	"version": "6.0.0",
	"description": "TOUCHSPOT ESLint config",
	"keywords": [
		"eslint",
		"typescript"
	],
	"homepage": "https://github.com/touchspot/eslint-config/tree/main/packages/eslint-config",
	"bugs": {
		"url": "https://github.com/touchspot/eslint-config/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/touchspot/eslint-config.git",
		"directory": "packages/eslint-config"
	},
	"license": "MIT",
	"author": "mozisan <mozisan@users.noreply.github.com>",
	"type": "module",
	"imports": {
		"#src/*.js": "./src/*.ts",
		"#test/*.js": "./test/*.ts"
	},
	"exports": {
		"./package.json": "./package.json",
		".": "./dist/index.mjs",
		"./*": "./dist/frameworks/*.mjs"
	},
	"files": [
		"dist",
		"package.json",
		"README.md",
		"!**/*.tsbuildinfo",
		"!**/*.test.*",
		"!**/__snapshots__/"
	],
	"scripts": {
		"build": "tsdown",
		"check:format": "prettier --check --log-level=warn .",
		"check:lint": "eslint .",
		"check:type": "tsc --noEmit",
		"fix:format": "prettier --write --log-level=warn .",
		"fix:lint": "eslint --fix .",
		"inspect": "config-inspector",
		"test": "vitest run --configLoader=runner --coverage",
		"test:update": "vitest run --configLoader=runner --update"
	},
	"prettier": "@touchspot/prettier-config",
	"dependencies": {
		"@eslint/compat": "catalog:",
		"@eslint/config-helpers": "catalog:",
		"@eslint/js": "catalog:",
		"@next/eslint-plugin-next": "catalog:",
		"eslint-config-prettier": "catalog:",
		"eslint-import-resolver-typescript": "catalog:",
		"eslint-plugin-better-tailwindcss": "catalog:",
		"eslint-plugin-check-file": "catalog:",
		"eslint-plugin-functional": "catalog:",
		"eslint-plugin-import-x": "catalog:",
		"eslint-plugin-no-relative-import-paths": "catalog:",
		"eslint-plugin-perfectionist": "catalog:",
		"eslint-plugin-react": "catalog:",
		"eslint-plugin-react-hooks": "catalog:",
		"eslint-plugin-unicorn": "catalog:",
		"eslint-plugin-unused-imports": "catalog:",
		"globals": "catalog:",
		"typescript-eslint": "catalog:"
	},
	"devDependencies": {
		"eslint": "catalog:",
		"next": "catalog:",
		"react": "catalog:",
		"react-dom": "catalog:",
		"tailwindcss": "catalog:",
		"tsdown": "catalog:"
	},
	"peerDependencies": {
		"eslint": "^10",
		"next": "^15 || ^16",
		"react": "^19",
		"react-dom": "^19",
		"tailwindcss": "^3 || ^4"
	},
	"peerDependenciesMeta": {
		"next": {
			"optional": true
		},
		"react": {
			"optional": true
		},
		"react-dom": {
			"optional": true
		},
		"tailwindcss": {
			"optional": true
		}
	},
	"publishConfig": {
		"access": "public"
	}
}
