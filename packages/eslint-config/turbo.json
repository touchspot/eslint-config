{
	"$schema": "https://turbo.build/schema.json",
	"extends": ["//"],
	"tasks": {
		"check:lint": {
			"dependsOn": ["^build", "build"],
			"inputs": ["lib/", "src/", "test/", "*.ts", "*.js", "tsconfig.json", "!**/__snapshots__/"],
			"outputs": []
		},
		"check:type": {
			"dependsOn": ["^build", "build"],
			"inputs": ["lib/", "src/", "test/", "tsconfig.json", "!**/__snapshots__/"],
			"outputs": []
		},
		"fix:lint": {
			"dependsOn": ["^build", "build", "fix:format"],
			"cache": false
		},
		"test": {
			"dependsOn": ["^build", "build"],
			"inputs": ["lib/", "src/", "test/", "tsconfig.json", "tsdown.config.*", "vitest.*"],
			"outputs": ["coverage/**"]
		},
		"test:update": {
			"dependsOn": ["^build", "build"],
			"inputs": ["lib/", "src/", "test/", "tsconfig.json", "tsdown.config.*", "vitest.*", "!**/__snapshots__/"],
			"outputs": ["**/__snapshots__/**"]
		}
	}
}
